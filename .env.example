# Supabase — public, read-only access for the site.
# Get these from the Supabase dashboard → Project Settings → API.
# Copy this file to .env.local and fill in the values (.env.local is gitignored).
#
# Project URL, e.g. https://abcdxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# The "anon" / public key (NOT the service_role key - that must never be committed).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# SERVER-ONLY secrets for the inquiry flow. NO NEXT_PUBLIC_ prefix, so they are
# never shipped to the browser. Never commit real values (.env.local is ignored).
# ---------------------------------------------------------------------------
# Supabase service_role secret (Project Settings -> API -> service_role).
# Used server-side ONLY to insert into the RLS-locked `inquiries` table.
SUPABASE_SERVICE_ROLE_KEY=
# Resend API key (resend.com -> API Keys). Enables the inquiry notification email.
# If unset, inquiries still SAVE to Supabase; only the email is skipped.
RESEND_API_KEY=
# Optional overrides for the notification email (sensible defaults are built in):
# INQUIRY_NOTIFY_EMAIL=hitchd.ph@gmail.com
# INQUIRY_FROM_EMAIL=Hitchd <onboarding@resend.dev>
# Founding-supplier APPLICATION notifications reuse RESEND_API_KEY and INQUIRY_FROM_EMAIL.
# Optional: send application alerts to a different inbox than inquiries.
# Falls back to INQUIRY_NOTIFY_EMAIL, then the built-in default.
# APPLICATION_NOTIFY_EMAIL=hitchd.ph@gmail.com

# ---------------------------------------------------------------------------
# Admin allowlist (server-only, NO NEXT_PUBLIC_). Comma-separated emails that
# may edit privileged fields such as a supplier's categories from the dashboard.
# Empty/unset = no admins (category editing is locked for everyone).
# ---------------------------------------------------------------------------
ADMIN_EMAILS=
# HMAC signing key for the vendor claim-code ticket cookie (server-only).
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
CLAIM_TICKET_SECRET=
